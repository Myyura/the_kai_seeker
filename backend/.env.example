# The Kai Seeker - Backend Configuration
# Copy this file to .env and edit as needed.

APP_NAME=The Kai Seeker
HOST=127.0.0.1
PORT=8000

# Path to SQLite database (relative to backend/ or absolute)
DATABASE_URL=sqlite+aiosqlite:///./data/kai_seeker.db

# Directory containing prebuilt content artifacts (schools.json, questions.json, etc.)
CONTENT_DIR=./data/content

# Allowed frontend origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Directory where the frontend static export lives (for production serving)
STATIC_DIR=../frontend/out

# Default LLM provider (openai, anthropic, etc.)
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
